modules = ["bun", "nodejs-20", "postgresql-16", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BUN_INSTALL_CACHE_DIR=/tmp/bun-cache bun run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
run = ["bun", "run", ".output/server/index.mjs"]
build = ["bun", "run", "build"]

[objectStorage]
defaultBucketID = "replit-objstore-e515b9be-51fd-4ea9-87af-179fd3515872"
